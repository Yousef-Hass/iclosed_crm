    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "zod": "^3.21.4",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "@types/cors": "^2.8.13",
